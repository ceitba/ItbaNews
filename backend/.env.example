PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgres://user:pass@localhost:5432/itbanews

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must be registered in Google Cloud Console:
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback
# Where to redirect after successful admin login:
FRONTEND_ADMIN_URL=http://localhost:5173/admin

# JWT — run: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_KEY=
R2_BUCKET=itbanews-media
R2_PUBLIC_URL=https://media.itbanews.ar

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:5173,https://itbanews.ar
